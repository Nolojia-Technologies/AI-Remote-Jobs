# Files EAS Build should NOT upload (keeps the build archive small & fast).
node_modules/
.expo/
dist/
dist-test/
web-build/
*.log
.DS_Store

# Local env (Supabase vars are provided via eas.json "env" instead)
.env
.env.local

# Icon design working files (not needed by the build)
assets/icon-variations/

# native projects (regenerated by EAS managed prebuild)
android/
ios/
