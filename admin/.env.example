# ── Supabase (SAME project as the mobile app) ───────────────────────────────
# URL + anon key are safe to expose to the browser.
NEXT_PUBLIC_SUPABASE_URL=https://xuurnnvppxthnnsvrcgd.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Service-role key — SERVER ONLY. Never prefix with NEXT_PUBLIC_. Bypasses RLS;
# used for privileged dashboard reads and AI-generation writes.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ── AI provider — choose GPT or Claude ──────────────────────────────────────
# "openai" or "anthropic". Omit to auto-detect from whichever key is set below.
AI_PROVIDER=anthropic

# OpenAI (GPT-5) — SERVER ONLY. Used when AI_PROVIDER=openai.
# Also required for AI thumbnail/image generation (Claude can't generate images).
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-5

# Anthropic (Claude) — SERVER ONLY. Used when AI_PROVIDER=anthropic.
ANTHROPIC_API_KEY=sk-ant-...
ANTHROPIC_MODEL=claude-opus-4-8
